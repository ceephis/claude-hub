<style>
  @media print {
    .no-print { display: none !important; }
    .page-break { page-break-before: always; break-before: page; }
    body { background: white !important; }
    .report-page { box-shadow: none !important; }
  }
  @media screen {
    .print-only { display: none; }
  }
  .progress-bar-fill { transition: width 0.3s ease; }
</style>

<div class="min-h-screen bg-gray-100">

  <%!-- Navigation bar (hidden when printing) --%>
  <div class="no-print sticky top-0 z-50 bg-gray-900 border-b border-gray-700 px-6 py-3 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/" class="text-gray-400 hover:text-white text-sm transition-colors">← HQ</a>
      <span class="text-white font-semibold">Weekly Report</span>
      <span class="text-gray-400 text-sm">{format_date_range(@report.week_start, @report.week_end)}</span>
    </div>

    <div class="flex items-center gap-3">
      <a
        href={~p"/weekly-report?week=#{Date.to_iso8601(@prev_week)}"}
        class="text-sm text-gray-400 hover:text-white bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-lg transition-colors"
      >← Prev Week</a>
      <a
        href={~p"/weekly-report?week=#{Date.to_iso8601(@next_week)}"}
        class="text-sm text-gray-400 hover:text-white bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-lg transition-colors"
      >Next Week →</a>
      <a
        href="/portfolio-briefing"
        target="_blank"
        class="text-sm bg-emerald-600 hover:bg-emerald-500 text-white px-4 py-1.5 rounded-lg transition-colors font-medium"
      >📋 Portfolio Briefing</a>
      <button
        onclick="window.print()"
        class="text-sm bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-1.5 rounded-lg transition-colors font-medium"
      >⬇ Save as PDF</button>
    </div>
  </div>

  <%!-- Report wrapper --%>
  <div class="max-w-4xl mx-auto px-6 py-8 space-y-0">

    <%!-- ================================================================ --%>
    <%!-- PAGE 1: Timesheet --%>
    <%!-- ================================================================ --%>
    <div class="report-page bg-white shadow-sm rounded-xl p-10">

      <div class="mb-8 border-b border-gray-200 pb-6">
        <p class="text-xs font-semibold text-indigo-600 uppercase tracking-widest mb-1">Weekly Report</p>
        <h1 class="text-3xl font-bold text-gray-900">{format_date_range(@report.week_start, @report.week_end)}</h1>
      </div>

      <h2 class="text-lg font-semibold text-gray-800 mb-4">Timesheet</h2>

      <%= if @report.timesheet.days == [] do %>
        <p class="text-gray-400 italic">No hours logged this week.</p>
      <% else %>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="text-left py-2 pr-4 text-gray-500 font-medium w-24">Day</th>
              <th class="text-left py-2 pr-4 text-gray-500 font-medium">Project</th>
              <th class="text-right py-2 text-gray-500 font-medium w-16">Hours</th>
            </tr>
          </thead>
          <tbody>
            <%= for day <- @report.timesheet.days do %>
              <%!-- Day rows --%>
              <%= for {row, idx} <- Enum.with_index(day.rows) do %>
                <tr class={if rem(idx, 2) == 0, do: "bg-white", else: "bg-gray-50"}>
                  <td class="py-1.5 pr-4 text-gray-500 align-top">
                    <%= if idx == 0 do %>
                      <span class="font-medium text-gray-700">{day.day_name}</span>
                    <% end %>
                  </td>
                  <td class="py-1.5 pr-4 font-medium text-gray-800 align-top whitespace-nowrap">{row.project}</td>
                  <td class="py-1.5 text-right font-mono text-gray-800 align-top">{format_hours(row.hours)}</td>
                </tr>
              <% end %>
              <%!-- Day subtotal --%>
              <tr class="border-b border-gray-100">
                <td colspan="2" class="py-1.5 pr-4 text-right text-xs text-gray-400 italic">
                  {day.day_name} total
                </td>
                <td class="py-1.5 text-right font-mono text-sm font-semibold text-gray-700">
                  {format_hours(day.total)}
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="border-t-2 border-gray-300">
              <td colspan="2" class="pt-3 pb-1 pr-4 text-right font-semibold text-gray-700">Week Total</td>
              <td class="pt-3 pb-1 text-right font-mono font-bold text-indigo-600 text-base">
                {format_hours(@report.timesheet.total)}
              </td>
            </tr>
          </tfoot>
        </table>
      <% end %>
    </div>

    <%!-- ================================================================ --%>
    <%!-- PAGE 2: Project Progress --%>
    <%!-- ================================================================ --%>
    <div class="report-page page-break bg-white shadow-sm rounded-xl p-10 mt-6">

      <div class="mb-8 border-b border-gray-200 pb-6">
        <p class="text-xs font-semibold text-indigo-600 uppercase tracking-widest mb-1">Weekly Report</p>
        <h1 class="text-3xl font-bold text-gray-900">{format_date_range(@report.week_start, @report.week_end)}</h1>
      </div>

      <h2 class="text-lg font-semibold text-gray-800 mb-6">Active Projects</h2>

      <%= if @report.projects_progress == [] do %>
        <p class="text-gray-400 italic">No active projects.</p>
      <% else %>
        <div class="space-y-4">
          <%= for project <- @report.projects_progress do %>
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                  <span class="text-base">{status_emoji(project.status_key)}</span>
                  <span class="font-medium text-gray-800">{project.name}</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-400">{project.tasks_done}/{project.tasks_total} tasks</span>
                  <span class="text-sm font-semibold text-gray-700 w-10 text-right">{project.progress}%</span>
                </div>
              </div>
              <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div
                  class="progress-bar-fill h-full rounded-full bg-indigo-500"
                  style={"width: #{project.progress}%"}
                ></div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%!-- ================================================================ --%>
    <%!-- PAGES 3+: Changed projects — one per page --%>
    <%!-- ================================================================ --%>
    <%= if @report.changed_projects != [] do %>
      <%= for project <- @report.changed_projects do %>
        <div class="report-page page-break bg-white shadow-sm rounded-xl p-10 mt-6">

          <div class="mb-8 border-b border-gray-200 pb-6">
            <p class="text-xs font-semibold text-indigo-600 uppercase tracking-widest mb-1">Project Update</p>
            <h1 class="text-3xl font-bold text-gray-900">{project.name}</h1>
            <div class="flex items-center gap-4 mt-2 text-sm text-gray-500">
              <span>{project.status}</span>
              <%= if project.stack do %>
                <span class="text-gray-300">·</span>
                <span>{project.stack}</span>
              <% end %>
            </div>
          </div>

          <%= if project.next_action do %>
            <div class="mb-6 bg-indigo-50 border border-indigo-100 rounded-lg px-4 py-3">
              <p class="text-xs font-semibold text-indigo-500 uppercase tracking-wide mb-1">Next Action</p>
              <p class="text-gray-800">{project.next_action}</p>
            </div>
          <% end %>

          <h2 class="text-base font-semibold text-gray-700 mb-4">Checklist</h2>

          <%= if project.checklist == [] do %>
            <p class="text-gray-400 italic text-sm">No checklist items found.</p>
          <% else %>
            <div class="space-y-2">
              <%!-- Done items first, then pending --%>
              <%= for item <- Enum.sort_by(project.checklist, &(!&1.done)) do %>
                <div class={[
                  "flex items-start gap-3 py-1.5 px-3 rounded-lg",
                  if(item.done, do: "bg-green-50", else: "bg-gray-50")
                ]}>
                  <span class={["mt-0.5 text-base flex-shrink-0", if(item.done, do: "text-green-500", else: "text-gray-300")]}>
                    {if item.done, do: "✓", else: "○"}
                  </span>
                  <span class={["text-sm leading-relaxed", if(item.done, do: "text-green-800", else: "text-gray-700")]}>
                    {item.text}
                  </span>
                </div>
              <% end %>
            </div>

            <div class="mt-6 pt-4 border-t border-gray-100 flex items-center justify-between text-sm">
              <span class="text-gray-400">{project.tasks_done} of {project.tasks_total} complete</span>
              <span class="font-semibold text-indigo-600">{project.progress}%</span>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>

  </div>

  <div class="no-print h-16"></div>
</div>
